{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript"],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true
  },
  "rules": {
    "no-unused-vars": "warn"
  },
  "ignorePatterns": ["dist/**", "**/dist/**", "**/node_modules/**"]
}
